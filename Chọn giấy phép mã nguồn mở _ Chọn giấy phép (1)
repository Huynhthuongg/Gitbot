  .home h2 { color: rgb(199, 205, 206) !important; }
  .license-body pre { background-color: rgb(19, 19, 19) !important; border: 1px solid rgb(62, 62, 62) !important; }
  .note { color: rgb(159, 165, 166) !important; }
  strong { color: rgb(189, 189, 189) !important; }
  button, input, optgroup, select, textarea { color: black !important; }
